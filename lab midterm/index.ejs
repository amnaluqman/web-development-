<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Khaadi Clone</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="/css/auth.css" />

  <!-- ===== Slick Carousel CDN ===== -->
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css"/>
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css"/>

  <!-- ===== Carousel Custom Styles ===== -->
  <style>
    .product-carousel {
      margin: 30px auto;
      max-width: 1300px;
      padding: 0 60px;
      position: relative;
    }
    .product-carousel .product-card {
      margin: 0 12px;
    }
    .slide-counter {
      text-align: center;
      margin: 20px auto 10px;
      font-size: 18px;
      font-weight: bold;
      color: #333;
    }
    .slick-prev, .slick-next {
      background: #000 !important;
      width: 42px !important;
      height: 42px !important;
      border-radius: 50%;
      z-index: 10;
    }
    .slick-prev { left: 10px !important; }
    .slick-next { right: 10px !important; }
    .slick-prev:before, .slick-next:before {
      color: #fff !important;
      font-size: 22px;
      opacity: 1;
    }
    .slick-prev:hover, .slick-next:hover {
      background: #333 !important;
    }
  </style>
</head>
<body>

  <!-- ===== FLASH MESSAGES ===== -->
<% if (success_msg && success_msg.length > 0) { %>
  <div class="flash flash-success"><%= success_msg %></div>
<% } %>
<% if (error_msg && error_msg.length > 0) { %>
  <div class="flash flash-error"><%= error_msg %></div>
<% } %>

  <!-- ANNOUNCEMENT BAR -->
  <div class="announcement-bar">
    <p>Discover what's new this season with our latest styles <a href="#">right here.</a></p>
    <a href="#" class="track">TRACK</a>
  </div>

  <!-- NAVBAR -->
<nav class="navbar">
  <div class="logo">
    <img src="/logo.svg" alt="Khaadi" />
  </div>
  <button class="hamburger" id="hamburger">&#9776;</button>
  <ul class="nav-links" id="nav-links">
    <li><a href="#">NEW IN</a></li>
    <li><a href="#" class="orange">EID. EAT. REPEAT.</a></li>
    <li><a href="#">READY TO WEAR</a></li>
    <li><a href="#">FABRICS</a></li>
    <li><a href="#">FRAGRANCES</a></li>
    <li><a href="#" class="red">SALE</a></li>
    <li><a href="#" class="bold">NOW HAPPENING</a></li>
  </ul>
  <div class="nav-icons">
    <span><i class="fa-solid fa-magnifying-glass"></i></span>
    <span><i class="fa-regular fa-heart"></i></span>

    <!-- ===== DYNAMIC AUTH LINKS ===== -->
    <% if (currentUser) { %>
      <!-- LOGGED IN USER -->
      <span class="user-greeting">Hi, <%= currentUser.name %></span>
      <% if (currentUser.role === 'admin') { %>
        <a href="/admin" class="nav-auth-link admin-link">Admin Panel</a>
      <% } %>
      <a href="/logout" class="nav-auth-link logout-link">Logout</a>
    <% } else { %>
      <!-- GUEST USER -->
      <a href="/login" class="nav-auth-link">Login</a>
      <a href="/register" class="nav-auth-link register-link">Register</a>
    <% } %>

    <span><i class="fa-solid fa-bag-shopping"></i></span>
  </div>
</nav>

  <!-- HERO SECTION -->
  <section class="hero">
    <div class="hero-main">
      <img src="/hero.webp" alt="Hero Banner" />
    </div>
    <div class="hero-dots">
      <span class="dot active"></span>
      <span class="dot"></span>
      <span class="dot"></span>
      <span class="dot"></span>
    </div>
  </section>

  <!-- TOP PICKS SECTION -->
  <section class="top-picks">
    <h2>Top Picks for You</h2>
    <p class="sub">We've handpicked the styles we know you'll love. Explore what's trending now.</p>
    <div class="picks-grid">
      <img src="/picks.webp" alt="Top Picks" />
    </div>
  </section>

  <!-- ===== SLIDE COUNTER ===== -->
  <div class="slide-counter">
    Showing <span id="current-slide">1</span> of <span id="total-slides">6</span>
  </div>

  <!-- ===== PRODUCTS CAROUSEL ===== -->
  <section class="products-section">
    <div class="product-carousel">

      <div class="product-card">
        <div class="product-img-wrap">
          <img src="/product1.webp" alt="Product 1" />
          <button class="wishlist-btn">&#9825;</button>
        </div>
        <div class="product-info">
          <p class="product-type">Printed | Ripple Crinkle</p>
          <p class="product-name">Abstract Cotton Kurta</p>
          <p class="product-price"><span class="old-price">PKR 4,000</span> <span class="new-price">PKR 1,200</span></p>
          <span class="badge off">70% OFF</span>
          <span class="badge online">Exclusively Online</span>
        </div>
      </div>

      <div class="product-card">
        <div class="product-img-wrap">
          <img src="/product2.webp" alt="Product 2" />
          <button class="wishlist-btn">&#9825;</button>
        </div>
        <div class="product-info">
          <p class="product-type">Embroidered | Textured Cotton</p>
          <p class="product-name">Floral Tassel Kurta</p>
          <p class="product-price"><span class="old-price">PKR 4,300</span> <span class="new-price">PKR 2,150</span></p>
          <span class="badge off">50% OFF</span>
          <span class="badge restock">Restocked</span>
        </div>
      </div>

      <div class="product-card">
        <div class="product-img-wrap">
          <img src="/product3.webp" alt="Product 3" />
          <button class="wishlist-btn">&#9825;</button>
        </div>
        <div class="product-info">
          <p class="product-type">Embroidered | Cotton Dobby</p>
          <p class="product-name">Floral V-Neck Kurta</p>
          <p class="product-price"><span class="old-price">PKR 5,800</span> <span class="new-price">PKR 2,900</span></p>
          <span class="badge off">50% OFF</span>
        </div>
      </div>

      <div class="product-card">
        <div class="product-img-wrap">
          <img src="/product4.webp" alt="Product 4" />
          <button class="wishlist-btn">&#9825;</button>
        </div>
        <div class="product-info">
          <p class="product-type">Embroidered | Textured Cotton</p>
          <p class="product-name">Geometric Tassel Kurta</p>
          <p class="product-price"><span class="old-price">PKR 4,300</span> <span class="new-price">PKR 2,150</span></p>
          <span class="badge off">50% OFF</span>
          <span class="badge restock">Restocked</span>
        </div>
      </div>

      <div class="product-card">
        <div class="product-img-wrap">
          <img src="/product5.webp" alt="Product 5" />
          <button class="wishlist-btn">&#9825;</button>
        </div>
        <div class="product-info">
          <p class="product-type">Embroidered | Textured Cotton</p>
          <p class="product-name">Geometric Tassel Kurta</p>
          <p class="product-price"><span class="old-price">PKR 4,300</span> <span class="new-price">PKR 2,150</span></p>
          <span class="badge off">50% OFF</span>
          <span class="badge restock">Restocked</span>
        </div>
      </div>

      <div class="product-card">
        <div class="product-img-wrap">
          <img src="/product6.webp" alt="Product 6" />
          <button class="wishlist-btn">&#9825;</button>
        </div>
        <div class="product-info">
          <p class="product-type">Embroidered | Lawn</p>
          <p class="product-name">Longline Lawn Kurta</p>
          <p class="product-price"><span class="new-price">PKR 6,000</span></p>
        </div>
      </div>

    </div>
  </section>

  <!-- INFO BAR -->
  <section class="info-bar">
    <div class="info-item">
      <i class="fa-solid fa-truck info-icon"></i>
      <div>
        <p class="info-title">SHIPPING CHARGES</p>
        <p class="info-sub">Starting from Rs. 130</p>
      </div>
    </div>
    <div class="info-item">
      <i class="fa-solid fa-bag-shopping info-icon"></i>
      <div>
        <p class="info-title">TRACK YOUR ORDER</p>
        <p class="info-sub">Check status of your order.</p>
      </div>
    </div>
    <div class="info-item">
      <i class="fa-solid fa-location-dot info-icon"></i>
      <div>
        <p class="info-title">FIND STORES</p>
        <p class="info-sub">Stores countrywide across Pakistan, UK, UAE, US.</p>
      </div>
    </div>
  </section>

  <!-- NEED HELP -->
  <section class="help-section">
    <p class="help-title">NEED HELP?</p>
    <a href="#" class="faq-link">
      <i class="fa-regular fa-file"></i> FAQS
    </a>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-grid">
      <div class="footer-col">
        <h4>HELP</h4>
        <ul>
          <li><a href="#">Frequently Asked Questions</a></li>
          <li><a href="#">Terms &amp; Conditions</a></li>
          <li><a href="#">Privacy Policy</a></li>
          <li><a href="#">Disclaimer</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>MORE FROM KHAADI</h4>
        <ul>
          <li><a href="#">About Us</a></li>
          <li><a href="#">Blogs</a></li>
          <li><a href="#">Cloth Care</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>OUR SOCIALS</h4>
        <div class="social-icons">
          <a href="#" class="social-icon tiktok"><i class="fa-brands fa-tiktok"></i></a>
          <a href="#" class="social-icon youtube"><i class="fa-brands fa-youtube"></i></a>
          <a href="#" class="social-icon facebook"><i class="fa-brands fa-facebook-f"></i></a>
          <a href="#" class="social-icon instagram"><i class="fa-brands fa-instagram"></i></a>
        </div>
        <h4 class="newsletter-title">GET THE LATEST NEWS</h4>
        <div class="newsletter">
          <input type="email" placeholder="Email Address" />
          <button>CONFIRM</button>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="payment-left">
        <p>100% Safe Checkout</p>
        <div class="payment-icons">
          <span class="pay mastercard">MC</span>
          <span class="pay visa">VISA</span>
        </div>
      </div>
      <div class="footer-logo">
        <img src="/logo.svg" alt="Khaadi" />
      </div>
      <p class="copyright">Copyright &copy; 2026 Weaves Corporation Limited. All Rights Reserved.</p>
    </div>
  </footer>

  <script src="/script.js"></script>

  <!-- ===== jQuery + Slick Carousel JS ===== -->
  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>

  <!-- ===== AI-Enhanced Carousel Init Script ===== -->
  <script>
    $(document).ready(function() {
      var $carousel = $('.product-carousel');

      // Initialize Slick Carousel
      $carousel.slick({
        infinite: true,              // ✅ Infinite Loop
        slidesToShow: 3,             // ✅ 3 cards on desktop
        slidesToScroll: 1,
        autoplay: true,              // ✅ Auto-play
        autoplaySpeed: 5000,         // ✅ Every 5 seconds
        pauseOnHover: true,          // ✅ Pause auto-play on hover
        arrows: true,                // ✅ Prev/Next buttons
        dots: false,
        responsive: [
          {
            breakpoint: 1024,
            settings: { slidesToShow: 2 }   // ✅ 2 cards on tablet
          },
          {
            breakpoint: 600,
            settings: { slidesToShow: 1 }   // ✅ 1 card on mobile
          }
        ]
      });

      // ✅ Slide Counter — updates on every slide change
      $carousel.on('afterChange', function(event, slick, currentSlide) {
        $('#current-slide').text(currentSlide + 1);
      });
    });
  </script>

</body>
</html>