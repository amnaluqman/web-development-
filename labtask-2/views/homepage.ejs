<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nike. Just Do It.</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

  <!-- ===== TOP UTILITY BAR ===== -->
  <div class="util-bar">
    <div class="util-inner">
      <a href="#">Find a Store</a>
      <span>|</span>
      <a href="#">Help</a>
      <span>|</span>
      <a href="#">Join Us</a>
      <span>|</span>
      <a href="/contact-us">Contact Us</a>
    </div>
  </div>

  <!-- ===== NAVBAR ===== -->
  <header class="navbar">
    <div class="nav-inner">

      <a href="/" class="nike-logo" aria-label="Nike Home">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 24" width="64" height="24">
          <path d="M64 0L21.3 18.7C16 21.3 10.9 21.5 7.3 19 3.3 16.3 2.2 11 4.5 5.8L5 4.7 0 24l48-10.7c5.3-2.6 10.4-2.8 14-.3 4 2.7 5.1 8 2.8 13.2l-.5 1.1L69 8 64 0z" fill="black"/>
        </svg>
      </a>

      <nav class="nav-links" id="navLinks">
        <a href="/" onclick="closeMenu()">Home</a>
        <a href="#" onclick="closeMenu()">Men</a>
        <a href="#" onclick="closeMenu()">Women</a>
        <a href="#" onclick="closeMenu()">Kids</a>
        <a href="#" onclick="closeMenu()">Sale</a>
        <a href="/contact-us" onclick="closeMenu()">Contact Us</a>
      </nav>

      <div class="nav-right">
        <div class="nav-icons">
          <button class="icon-btn" aria-label="Search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </button>
          <button class="icon-btn" aria-label="Favourites">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
            </svg>
          </button>
          <button class="icon-btn" aria-label="Bag">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 01-8 0"/>
            </svg>
          </button>
        </div>
        <button class="hamburger" id="hamburger" aria-label="Toggle Menu" onclick="toggleMenu()">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

    </div>

    <!-- Mobile Menu -->
    <div class="mobile-menu" id="mobileMenu">
      <a href="/" onclick="closeMenu()">Home</a>
      <a href="#" onclick="closeMenu()">Men</a>
      <a href="#" onclick="closeMenu()">Women</a>
      <a href="#" onclick="closeMenu()">Kids</a>
      <a href="#" onclick="closeMenu()">Sale</a>
      <a href="/contact-us" onclick="closeMenu()">Contact Us</a>
    </div>
  </header>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <p class="hero-eyebrow">Just Dropped</p>
        <h1 class="hero-title">AIR MAX<br/>PULSE</h1>
        <p class="hero-desc">Inspired by the energy of East London's music scene, Air Max Pulse brings raw energy to your every step.</p>
        <div class="hero-btns">
          <a href="#" class="btn-black">Shop Now</a>
          <a href="/contact-us" class="btn-white">Contact Us</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-shoe-wrap">
          <div class="hero-glow"></div>
          <div class="hero-shoe-emoji">👟</div>
          <p class="hero-shoe-label">Air Max Pulse</p>
          <p class="hero-shoe-price">$150</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TRENDING PRODUCTS ===== -->
  <section class="trending">
    <div class="section-inner">
      <div class="row-header">
        <h2 class="section-title">Trending</h2>
        <a href="#" class="see-all">Shop All &#8250;</a>
      </div>
      <div class="products-row">
        <div class="p-card">
          <div class="p-img bg-grey">
            <div class="p-icon">👟</div>
            <button class="fav-btn">♡</button>
          </div>
          <div class="p-info">
            <span class="p-tag tag-new">Just In</span>
            <p class="p-cat">Lifestyle Shoes</p>
            <h4 class="p-name">Nike Air Force 1 '07</h4>
            <p class="p-colors">1 Colour</p>
            <p class="p-price">₨ 18,995</p>
          </div>
        </div>
        <div class="p-card">
          <div class="p-img bg-beige">
            <div class="p-icon">🥿</div>
            <button class="fav-btn">♡</button>
          </div>
          <div class="p-info">
            <p class="p-cat">Running Shoes</p>
            <h4 class="p-name">Nike Pegasus 41</h4>
            <p class="p-colors">3 Colours</p>
            <p class="p-price">₨ 22,995</p>
          </div>
        </div>
        <div class="p-card">
          <div class="p-img bg-dark">
            <div class="p-icon">👟</div>
            <button class="fav-btn">♡</button>
          </div>
          <div class="p-info">
            <span class="p-tag tag-member">Member Exclusive</span>
            <p class="p-cat">Lifestyle Shoes</p>
            <h4 class="p-name">Nike Dunk Low Retro</h4>
            <p class="p-colors">2 Colours</p>
            <p class="p-price">₨ 19,995</p>
          </div>
        </div>
        <div class="p-card">
          <div class="p-img bg-red">
            <div class="p-icon">🏃</div>
            <button class="fav-btn">♡</button>
          </div>
          <div class="p-info">
            <span class="p-tag tag-sale">Sale</span>
            <p class="p-cat">Training Shoes</p>
            <h4 class="p-name">Nike Metcon 9</h4>
            <p class="p-colors">4 Colours</p>
            <div class="price-row">
              <p class="p-price p-sale">₨ 17,495</p>
              <p class="p-price p-orig">₨ 22,995</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MEMBERSHIP ===== -->
  <section class="membership">
    <div class="section-inner">
      <div class="mem-inner">
        <div class="mem-text">
          <p class="mem-eyebrow">Nike Membership</p>
          <h2 class="mem-title">Become a Nike Member</h2>
          <p class="mem-desc">Sign up to get the best products, inspiration and stories from Nike. Membership is free.</p>
          <div class="mem-btns">
            <a href="#" class="btn-black">Join Us</a>
            <a href="/contact-us" class="btn-ghost">Contact Us</a>
          </div>
        </div>
        <div class="mem-perks">
          <div class="perk"><span class="perk-icon">🎁</span><p>Exclusive Member Drops</p></div>
          <div class="perk"><span class="perk-icon">🚚</span><p>Free Delivery &amp; Returns</p></div>
          <div class="perk"><span class="perk-icon">⚡</span><p>Early Access to Sales</p></div>
          <div class="perk"><span class="perk-icon">🏅</span><p>Nike App Rewards</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-cols">
        <div class="footer-col">
          <h4>Shoes</h4>
          <a href="#">All Shoes</a>
          <a href="#">Running Shoes</a>
          <a href="#">Basketball Shoes</a>
        </div>
        <div class="footer-col">
          <h4>Help</h4>
          <a href="#">Order Status</a>
          <a href="#">Delivery</a>
          <a href="/contact-us">Contact Us</a>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <a href="#">About Nike</a>
          <a href="#">Newsroom</a>
          <a href="#">Sustainability</a>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="footer-bottom-left">
          <p>&copy; 2025 Nike, Inc. All Rights Reserved</p>
        </div>
        <div class="footer-links">
          <a href="#">Terms of Use</a>
          <a href="#">Privacy Policy</a>
          <a href="/contact-us">Contact Us</a>
        </div>
      </div>
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>
