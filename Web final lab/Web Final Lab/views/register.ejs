<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Register | Khaadi</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body>

  <!-- ===== NAVBAR ===== -->
  <header class="navbar">
    <a href="/" class="logo">
      <img src="/logo.svg" alt="Khaadi Logo" />
    </a>
    <nav class="nav-links">
      <a href="/">Home</a>
      <a href="/products">Products</a>
      <a href="/login">Login</a>
    </nav>
  </header>

  <!-- ===== FLASH MESSAGES ===== -->
  <% if (success_msg && success_msg.length > 0) { %>
    <div class="flash flash-success"><%= success_msg %></div>
  <% } %>
  <% if (error_msg && error_msg.length > 0) { %>
    <div class="flash flash-error"><%= error_msg %></div>
  <% } %>

  <!-- ===== REGISTER FORM ===== -->
  <section class="auth-section">
    <div class="auth-card">
      <h1>Create an Account</h1>
      <p class="auth-subtitle">Join Khaadi today — it only takes a minute.</p>

      <form action="/register" method="POST" class="auth-form">
        
        <div class="form-group">
          <label for="name">Full Name</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            placeholder="Enter your full name"
            required 
          />
        </div>

        <div class="form-group">
          <label for="email">Email Address</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            placeholder="example@email.com"
            required 
          />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            placeholder="At least 6 characters"
            minlength="6"
            required 
          />
        </div>

        <button type="submit" class="auth-btn">Create Account</button>
      </form>

      <p class="auth-footer">
        Already have an account? <a href="/login">Sign in</a>
      </p>
    </div>
  </section>

</body>
</html>