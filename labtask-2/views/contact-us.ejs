<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us | Nike</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>

  <!-- ===== NAVBAR ===== -->
  <header class="navbar">
    <div class="nav-inner">
      <a href="/" class="nike-logo" aria-label="Nike Home">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 24" width="64" height="24">
          <path d="M64 0L21.3 18.7C16 21.3 10.9 21.5 7.3 19 3.3 16.3 2.2 11 4.5 5.8L5 4.7 0 24l48-10.7c5.3-2.6 10.4-2.8 14-.3 4 2.7 5.1 8 2.8 13.2l-.5 1.1L69 8 64 0z" fill="black"/>
        </svg>
      </a>
      <nav class="nav-links">
        <a href="/">Home</a>
        <a href="#">Men</a>
        <a href="#">Women</a>
        <a href="#">Kids</a>
        <a href="#">Sale</a>
        <a href="/contact-us">Contact Us</a>
      </nav>
      <div class="nav-right">
        <button class="hamburger" id="hamburger" onclick="toggleMenu()">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
    <div class="mobile-menu" id="mobileMenu">
      <a href="/" onclick="closeMenu()">Home</a>
      <a href="#" onclick="closeMenu()">Men</a>
      <a href="#" onclick="closeMenu()">Women</a>
      <a href="/contact-us" onclick="closeMenu()">Contact Us</a>
    </div>
  </header>

  <!-- ===== CONTACT PAGE ===== -->
  <section class="contact-section">
    <div class="contact-inner">
      <div class="contact-text">
        <p class="contact-eyebrow">Get In Touch</p>
        <h1 class="contact-title">Contact Us</h1>
        <p class="contact-desc">We're here to help. Reach out to us and we'll get back to you as soon as possible.</p>

        <div class="contact-info">
          <div class="contact-info-item">
            <span class="contact-icon">📞</span>
            <div>
              <h4>Call Us</h4>
              <p>1-800-806-6453</p>
              <p>Mon–Fri, 9am–9pm EST</p>
            </div>
          </div>
          <div class="contact-info-item">
            <span class="contact-icon">💬</span>
            <div>
              <h4>Live Chat</h4>
              <p>Available 24/7</p>
              <p>Average wait: 2 mins</p>
            </div>
          </div>
          <div class="contact-info-item">
            <span class="contact-icon">✉️</span>
            <div>
              <h4>Email Us</h4>
              <p>support@nike.com</p>
              <p>Reply within 24 hours</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="contact-form-wrap">
        <h2>Send Us a Message</h2>
        <div class="contact-form">
          <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" placeholder="Your full name" />
          </div>
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" placeholder="your@email.com" />
          </div>
          <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" placeholder="How can we help?" />
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" rows="5" placeholder="Tell us more..."></textarea>
          </div>
          <button type="button" class="btn-black btn-full">Send Message</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-bottom">
        <div class="footer-bottom-left">
          <p>&copy; 2025 Nike, Inc. All Rights Reserved</p>
        </div>
        <div class="footer-links">
          <a href="/">Home</a>
          <a href="#">Terms of Use</a>
          <a href="#">Privacy Policy</a>
        </div>
      </div>
    </div>
  </footer>

  <script src="/script.js"></script>
</body>
</html>
